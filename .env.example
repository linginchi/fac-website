# FAC Platform V5.1 - Environment Variables Example
# 复制此文件为 .env 并填写实际值

# ============================================
# 前端环境变量 (Vite)
# ============================================

# API 基础路径 (开发环境)
VITE_API_BASE=http://localhost:8788/api

# API 基础路径 (生产环境 - 同域部署)
# VITE_API_BASE=/api

# 平台信息
VITE_PLATFORM_VERSION=V5.1-ALPHA
VITE_PLATFORM_NAME=港匠匯 FAC

# ============================================
# 后端环境变量 (Wrangler Secrets)
# 使用 `wrangler secret put KEY_NAME` 设置
# ============================================

# JWT 签名密钥
# JWT_SECRET=your-jwt-secret-here

# 支付相关 (Stripe)
# STRIPE_PUBLIC_KEY=pk_test_...
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...

# LinkedIn OAuth
# LINKEDIN_CLIENT_ID=your-linkedin-client-id
# LINKEDIN_CLIENT_SECRET=your-linkedin-client-secret

# 邮件服务 (Resend/SendGrid)
# RESEND_API_KEY=re_...
# EMAIL_FROM=noreply@hkfac.com

# ============================================
# 数据库配置 (wrangler.toml 中管理)
# ============================================
# D1_DATABASE_ID=your-d1-database-id
# KV_NAMESPACE_ID=your-kv-namespace-id
